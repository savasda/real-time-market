{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "client",
  "projectType": "application",
  "sourceRoot": "apps/client/src",
  "prefix": "app",
  "tags": ["type:app", "scope:client"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "browser": "apps/client/src/main.ts",
        "tsConfig": "apps/client/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/client/public"
          }
        ],
        "styles": ["apps/client/src/styles.scss"],
        "outputPath": "dist/apps/client"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "client:build:production"
        },
        "development": {
          "buildTarget": "client:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:karma",
      "options": {
        "tsConfig": "apps/client/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/client/public"
          }
        ],
        "styles": ["apps/client/src/styles.scss"]
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"apps/client/src/**/*.ts\" \"apps/client/src/**/*.html\" && stylelint \"apps/client/src/**/*.scss\""
      }
    }
  }
}
